<% layout("/layouts/boilerplate.ejs") %>

    <div id="filters-wrapper" class="position-relative d-flex align-items-center">
        <button id="slideLeft" class="slider-btn d-none d-md-flex" aria-label="Scroll left"><i
                class="fa-solid fa-chevron-left"></i></button>
        <div id="filters-container" class="flex-grow-1">
            <% const categories=[ { id: "Trending" , icon: "fa-fire" }, { id: "Rooms" , icon: "fa-bed" }, {
                id: "Iconic Cities" , icon: "fa-mountain-city" }, { id: "Mountains" , icon: "fa-mountain" }, {
                id: "Nature" , icon: "fa-tree" }, { id: "Pool" , icon: "fa-person-swimming" }, { id: "Camping" ,
                icon: "fa-campground" }, { id: "Farm" , icon: "fa-cow" }, { id: "Arctic" , icon: "fa-snowman" }, {
                id: "Dome" , icon: "fa-igloo" }, { id: "Boat" , icon: "fa-ship" } ]; %>

                <% for(let cat of categories) { %>
                    <div
                        class="filter-box <%= typeof category !== 'undefined' && category === cat.id ? 'active' : '' %>">
                        <a
                            href="/listings?category=<%= encodeURIComponent(cat.id) %><%= typeof search !== 'undefined' && search ? '&search='+encodeURIComponent(search) : '' %><%= typeof sort !== 'undefined' && sort ? '&sort='+encodeURIComponent(sort) : '' %>">
                            <i class="fa-solid <%= cat.icon %>"></i>
                            <p>
                                <%= cat.id %>
                            </p>
                        </a>
                    </div>
                    <% } %>

                        <% if ((typeof category !=='undefined' && category) || (typeof search !=='undefined' && search))
                            { %>
                            <div class="filter-box" style="margin-left: auto; padding-right: 1.5rem;">
                                <a href="/listings">
                                    <i class="fa-solid fa-circle-xmark text-danger" style="font-size: 1.4rem;"></i>
                                    <p>Reset</p>
                                </a>
                            </div>
                            <% } %>
        </div>
        <button id="slideRight" class="slider-btn d-none d-md-flex" aria-label="Scroll right"><i
                class="fa-solid fa-chevron-right"></i></button>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const leftBtn = document.getElementById('slideLeft');
            const rightBtn = document.getElementById('slideRight');
            const filtersContainer = document.getElementById('filters-container');

            if (leftBtn && rightBtn && filtersContainer) {
                leftBtn.addEventListener('click', () => {
                    filtersContainer.scrollBy({ left: -300, behavior: 'smooth' });
                });

                rightBtn.addEventListener('click', () => {
                    filtersContainer.scrollBy({ left: 300, behavior: 'smooth' });
                });
            }
        });
    </script>

    <div class="controls-bar">
        <div class="d-flex gap-3 align-items-center flex-wrap">
            <form action="/listings" method="GET" class="d-flex align-items-center m-0">
                <% if(typeof search !=='undefined' && search) { %><input type="hidden" name="search"
                        value="<%= search %>">
                    <% } %>
                        <% if(typeof category !=='undefined' && category) { %><input type="hidden" name="category"
                                value="<%= category %>">
                            <% } %>
                                <select name="sort" class="form-select sort-select" onchange="this.form.submit()">
                                    <option value="newest" <%=typeof sort !=='undefined' && sort==='newest' ? 'selected'
                                        : '' %>>Newest First</option>
                                    <option value="price_asc" <%=typeof sort !=='undefined' && sort==='price_asc'
                                        ? 'selected' : '' %>>Price: Low to High</option>
                                    <option value="price_desc" <%=typeof sort !=='undefined' && sort==='price_desc'
                                        ? 'selected' : '' %>>Price: High to Low</option>
                                </select>
            </form>

            <div class="tax-toggle">
                <div class="form-check-reverse form-switch m-0">
                    <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                    <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
                </div>
            </div>
        </div>

        <% if(typeof search !=='undefined' && search) { %>
            <div class="text-muted small">
                Results for "<b>
                    <%= search %>
                </b>"
            </div>
            <% } %>
    </div>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3 g-4">
        <% if(typeof allListings !=='undefined' && allListings.length===0) { %>
            <div class="col-12 mt-5 text-center" style="width: 100%;">
                <br><br>
                <h4 style="color: #484848;">No listings found <i class="fa-regular fa-face-frown text-muted"></i></h4>
                <p class="text-muted mt-2">Try adjusting your filters, clearing your search query, or checking back
                    later.</p>
                <a href="/listings" class="btn btn-outline-dark mt-3" style="border-radius:2rem;">Clear all filters</a>
            </div>
            <% } %>

                <% if (typeof allListings !=='undefined' ) { %>
                    <% for(let listing of allListings) { %>
                        <div class="col">
                            <a href="/listings/<%=listing._id%>" class="listing-link">
                                <div class="card listing-card h-100">
                                    <div class="image-wrapper">
                                        <img src="<%=listing.image.url%>" class="card-img-top" alt="<%=listing.title%>"
                                            style="height:20rem; object-fit: cover;">
                                        <div class="card-img-overlay">
                                            <% if(currUser) { %>
                                                <form action="/profile/wishlist/<%=listing._id%>" method="POST"
                                                    style="position: absolute; top: 1rem; right: 1rem; z-index: 10;">
                                                    <button class="btn wishlist-btn p-0" type="submit"
                                                        style="background: none; border: none;">
                                                        <i class="fa-<%= (currUser.wishlist && currUser.wishlist.some(id => id.toString() === listing._id.toString())) ? 'solid' : 'regular' %> fa-heart"
                                                            style="font-size: 1.5rem; color: #fe424d; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));"></i>
                                                    </button>
                                                </form>
                                                <% } %>
                                        </div>
                                    </div>
                                    <div class="card-body">
                                        <b>
                                            <%= listing.title %>
                                        </b>
                                        <% if (listing.category) { %>
                                            <span class="badge rounded-pill bg-light text-dark ms-2 fw-normal"
                                                style="border:1px solid #ddd;">
                                                <%= listing.category %>
                                            </span>
                                            <% } %>
                                                <div class="listing-location text-muted mt-1"><i
                                                        class="fa-solid fa-location-dot"></i>
                                                    <%= listing.location %>, <%= listing.country %>
                                                </div>
                                                <div class="listing-price mt-2"
                                                    style="font-size: 1.1rem; color: #fe424d; font-weight: 600;">
                                                    &#8377;<%= listing.price.toLocaleString("en-IN") %> <span
                                                            style="font-weight: 400; color: #222; font-size: 0.95rem;">/
                                                            night</span>
                                                        <i class="tax-info text-muted"
                                                            style="display: none; font-size: 0.85rem; font-weight: 400;">&nbsp;+18%
                                                            GST</i>
                                                </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                        <%}%>
                            <% } %>
    </div>

    <!-- Pagination Controls -->
    <% if (typeof totalPages !=='undefined' && totalPages> 1) { %>
        <nav class="mt-5 mb-5 d-flex justify-content-center">
            <ul class="pagination">
                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                    <a class="page-link shadow-sm"
                        href="/listings?page=<%= currentPage - 1 %><%= typeof category !== 'undefined' && category ? '&category=' + encodeURIComponent(category) : '' %><%= typeof search !== 'undefined' && search ? '&search=' + encodeURIComponent(search) : '' %><%= typeof sort !== 'undefined' && sort ? '&sort=' + encodeURIComponent(sort) : '' %>">
                        <i class="fa-solid fa-chevron-left text-muted"></i>
                    </a>
                </li>

                <% for(let i=1; i <=totalPages; i++) { %>
                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                        <a class="page-link shadow-sm"
                            href="/listings?page=<%= i %><%= typeof category !== 'undefined' && category ? '&category=' + encodeURIComponent(category) : '' %><%= typeof search !== 'undefined' && search ? '&search=' + encodeURIComponent(search) : '' %><%= typeof sort !== 'undefined' && sort ? '&sort=' + encodeURIComponent(sort) : '' %>">
                            <%= i %>
                        </a>
                    </li>
                    <% } %>

                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link shadow-sm"
                                href="/listings?page=<%= currentPage + 1 %><%= typeof category !== 'undefined' && category ? '&category=' + encodeURIComponent(category) : '' %><%= typeof search !== 'undefined' && search ? '&search=' + encodeURIComponent(search) : '' %><%= typeof sort !== 'undefined' && sort ? '&sort=' + encodeURIComponent(sort) : '' %>">
                                <i class="fa-solid fa-chevron-right text-muted"></i>
                            </a>
                        </li>
            </ul>
        </nav>
        <% } %>

            <script>
                document.addEventListener("DOMContentLoaded", () => {
                    let taxSwitch = document.getElementById("switchCheckDefault");
                    taxSwitch.addEventListener("change", (e) => {
                        let taxInfos = document.querySelectorAll(".tax-info");
                        for (let info of taxInfos) {
                            if (e.target.checked) {
                                info.style.display = "inline";
                            } else {
                                info.style.display = "none";
                            }
                        }
                    });
                });
            </script>