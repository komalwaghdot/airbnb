<% layout("/layouts/boilerplate") %>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <i class="fa-solid fa-compass"></i>
                <h2>Create Account</h2>
                <p>Join Wanderlust and start exploring the world</p>
            </div>
            <form action="/signup" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-user"></i></span>
                        <input name="username" id="username" type="text" class="form-control"
                            placeholder="Choose a username" required />
                    </div>
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-envelope"></i></span>
                        <input name="email" id="email" type="email" class="form-control" placeholder="Enter your email"
                            required />
                    </div>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                        <input name="password" id="password" type="password" class="form-control"
                            placeholder="Create a password" required />
                    </div>
                </div>

                <div class="mb-4 mt-4">
                    <label class="form-label d-block mb-3">Join as a...</label>
                    <div class="d-flex gap-3">
                        <div class="form-check border rounded p-3 flex-fill text-center"
                            style="cursor: pointer; background: #f8f9fa;">
                            <input class="form-check-input float-none mx-auto d-block mb-2" type="radio" name="role"
                                id="roleUser" value="user" checked>
                            <label class="form-check-label d-block" style="cursor: pointer;" for="roleUser">
                                <i class="fa-solid fa-suitcase-rolling d-block mb-1"
                                    style="font-size: 1.5rem; color: #555;"></i>
                                <span style="font-weight: 600; color: #333;">Guest</span>
                                <small class="d-block text-muted mt-1" style="font-size: 0.75rem;">I want to book
                                    places</small>
                            </label>
                        </div>
                        <div class="form-check border rounded p-3 flex-fill text-center"
                            style="cursor: pointer; background: #f8f9fa;">
                            <input class="form-check-input float-none mx-auto d-block mb-2" type="radio" name="role"
                                id="roleHost" value="host">
                            <label class="form-check-label d-block" style="cursor: pointer;" for="roleHost">
                                <i class="fa-solid fa-house-user d-block mb-1"
                                    style="font-size: 1.5rem; color: #fe424d;"></i>
                                <span style="font-weight: 600; color: #333;">Host</span>
                                <small class="d-block text-muted mt-1" style="font-size: 0.75rem;">I want to list
                                    properties</small>
                            </label>
                        </div>
                    </div>
                </div>

                <button class="btn btn-auth mt-2"><i class="fa-solid fa-user-plus"></i> Sign Up</button>
            </form>
            <p class="text-center mt-3" style="font-size: 0.88rem; color: #717171;">
                Already have an account? <a href="/login"
                    style="color: #fe424d; font-weight: 600; text-decoration: none;">Log In</a>
            </p>
        </div>
    </div>