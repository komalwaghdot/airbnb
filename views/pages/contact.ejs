<% layout("/layouts/boilerplate.ejs") %>

<style>
    body {
        background-color: #fcfcfc; /* Off-white for better contrast with elements */
    }
    .contact-container {
        padding: 4rem 0;
    }
    .contact-info-card {
        background: linear-gradient(135deg, #fe424d 0%, #d42a35 100%);
        color: white;
        border-radius: 2rem;
        padding: 4rem;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        box-shadow: 0 20px 50px rgba(254, 66, 77, 0.35);
        position: relative;
        overflow: hidden;
    }
    .contact-info-card::before {
        content: '';
        position: absolute;
        top: -50px;
        right: -50px;
        width: 150px;
        height: 150px;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
    }
    .info-item {
        display: flex;
        align-items: center;
        margin-bottom: 2.5rem;
        transition: transform 0.3s ease;
    }
    .info-item:hover {
        transform: translateX(10px);
    }
    .info-icon {
        width: 60px;
        height: 60px;
        background: rgba(255,255,255,0.25);
        backdrop-filter: blur(5px);
        border-radius: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 1.5rem;
        font-size: 1.5rem;
        box-shadow: 0 8px 15px rgba(0,0,0,0.1);
    }
    .highlighted-form-wrapper {
        background: white;
        border-radius: 2rem;
        padding: 4rem;
        border: 1px solid rgba(254, 66, 77, 0.2);
        box-shadow: 0 15px 45px rgba(254, 66, 77, 0.12), 0 0 20px rgba(254, 66, 77, 0.05);
        position: relative;
    }
    .highlighted-form-wrapper::after {
        content: '';
        position: absolute;
        top: -2px;
        left: -2px;
        right: -2px;
        bottom: -2px;
        z-index: -1;
        background: linear-gradient(135deg, #fe424d, transparent, #fe424d);
        border-radius: 2rem;
        opacity: 0.1;
    }
    .form-label {
        font-weight: 700;
        color: #333;
        margin-bottom: 0.75rem;
    }
    .form-control, .form-select {
        border: 2px solid #f0f0f0;
        padding: 1rem 1.5rem;
        border-radius: 1rem;
        transition: all 0.3s ease;
        background-color: #fdfdfd;
    }
    .form-control:focus, .form-select:focus {
        border-color: #fe424d;
        background-color: white;
        box-shadow: 0 0 0 0.25rem rgba(254, 66, 77, 0.1);
        outline: none;
    }
    .submit-btn {
        background: #fe424d;
        color: white;
        border: none;
        padding: 1.2rem;
        border-radius: 1.2rem;
        font-weight: 800;
        font-size: 1.1rem;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
        margin-top: 1rem;
        box-shadow: 0 8px 25px rgba(254, 66, 77, 0.25);
    }
    .submit-btn:hover {
        background: #e32d38;
        transform: translateY(-3px);
        box-shadow: 0 12px 35px rgba(254, 66, 77, 0.35);
    }
    .map-box {
        width: 100%;
        height: 250px;
        background: url('https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?q=80&w=2066&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        border-radius: 1.5rem;
        margin-top: 3rem;
        border: 1px solid #eee;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }
    .map-box::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(254, 66, 77, 0.1);
    }
    .map-tag {
        position: relative;
        background: white;
        padding: 0.75rem 1.5rem;
        border-radius: 1rem;
        font-weight: 700;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        border-left: 4px solid #fe424d;
    }
</style>

<div class="container contact-container">
    <div class="row g-5">
        <!-- Contact Info -->
        <div class="col-lg-5">
            <div class="contact-info-card shadow">
                <h1 class="fw-bold mb-3">Let's Talk!</h1>
                <p class="mb-5 fs-5 pb-3 border-bottom border-white border-opacity-25">We typically respond to all inquiries within a few business hours.</p>

                <div class="info-item">
                    <div class="info-icon"><i class="fa-solid fa-phone"></i></div>
                    <div>
                        <div class="small text-uppercase opacity-75 fw-bold letter-spacing-1">Phone</div>
                        <div class="fs-5 fw-bold">+1 (555) 123-4567</div>
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-icon"><i class="fa-solid fa-envelope"></i></div>
                    <div>
                        <div class="small text-uppercase opacity-75 fw-bold letter-spacing-1">Email</div>
                        <div class="fs-5 fw-bold">hello@wanderlust.com</div>
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-icon"><i class="fa-solid fa-location-dot"></i></div>
                    <div>
                        <div class="small text-uppercase opacity-75 fw-bold letter-spacing-1">Visit Us</div>
                        <div class="fs-5 fw-bold">123 Travel HQ, Global Plaza</div>
                    </div>
                </div>

                <div class="mt-5 d-flex gap-4 fs-4 pt-4">
                    <a href="#" class="text-white opacity-75 hover-opacity-100"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#" class="text-white opacity-75 hover-opacity-100"><i class="fa-brands fa-twitter"></i></a>
                    <a href="#" class="text-white opacity-75 hover-opacity-100"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#" class="text-white opacity-75 hover-opacity-100"><i class="fa-brands fa-linkedin-in"></i></a>
                </div>
            </div>
        </div>

        <!-- Contact Form -->
        <div class="col-lg-7">
            <div class="highlighted-form-wrapper">
                <h2 class="fw-bold mb-5" style="color: #222;">Send a Message</h2>
                <form action="/contact" method="GET" class="needs-validation" onsubmit="event.preventDefault(); alert('Message sent successfully!'); this.reset();" novalidate>
                    <div class="row g-4">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">First Name</label>
                            <input type="text" class="form-control" placeholder="John" required>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Last Name</label>
                            <input type="text" class="form-control" placeholder="Doe" required>
                        </div>
                    </div>
                    
                    <div class="mb-4 mt-3">
                        <label class="form-label">Email Address</label>
                        <input type="email" class="form-control" placeholder="john@example.com" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Inquiry Type</label>
                        <select class="form-select">
                            <option selected>General Support</option>
                            <option>Booking Issues</option>
                            <option>Host Partnerships</option>
                            <option>Advertising</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">How can we help?</label>
                        <textarea class="form-control" rows="5" placeholder="Write your message here..." required></textarea>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="submit-btn">Send Secure Message <i class="fa-solid fa-paper-plane ms-2 small"></i></button>
                    </div>
                </form>

                <div class="map-box shadow-sm">
                    <div class="map-tag"><i class="fa-solid fa-map-pin text-danger me-2"></i> Our Global HQ</div>
                </div>
            </div>
        </div>
    </div>
</div>
